#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>
#include <sys/stat.h>
#include <dirent.h>

int main() {
    int fd;
    struct stat st;
    DIR *d;
    struct dirent *dir;

    fd = open("sample.txt", O_RDONLY);

    fcntl(fd, F_SETFL, O_RDONLY);

    lseek(fd, 0, SEEK_SET);

    stat("sample.txt", &st);

    printf("File Size = %ld bytes\n", st.st_size);

    d = opendir(".");

    printf("\nDirectory Contents:\n");

    while((dir = readdir(d)) != NULL)
        printf("%s\n", dir->d_name);

    closedir(d);
    close(fd);

    return 0;
}
