#include <stdio.h>
#include <stdlib.h>

int main()
{
    int queue[100];
    int n, head, i;
    int seek = 0;

    printf("Enter number of requests: ");
    scanf("%d", &n);

    printf("Enter request queue:\n");
    for(i = 0; i < n; i++)
        scanf("%d", &queue[i]);

    printf("Enter initial head position: ");
    scanf("%d", &head);

    for(i = 0; i < n; i++)
    {
        seek += abs(head - queue[i]);
        head = queue[i];
    }

    printf("\nTotal Seek Time = %d\n", seek);

    return 0;
}
