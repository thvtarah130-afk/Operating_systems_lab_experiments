#include <stdio.h>

int main()
{
    int n, i, tq;
    int arrival[10], burst[10], rem[10];
    int wt[10], tat[10];
    int complete = 0, time = 0;
    float avg_wt = 0, avg_tat = 0;

    printf("Total number of process in the system: ");
    scanf("%d", &n);

    for(i = 0; i < n; i++)
    {
        printf("\nEnter the Arrival and Burst time of the Process[%d]\n", i + 1);

        printf("Arrival time is: ");
        scanf("%d", &arrival[i]);

        printf("\nBurst time is: ");
        scanf("%d", &burst[i]);

        rem[i] = burst[i];
    }

    printf("\nEnter the Time Quantum for the process: ");
    scanf("%d", &tq);

    while(complete < n)
    {
        int flag = 0;

        for(i = 0; i < n; i++)
        {
            if(arrival[i] <= time && rem[i] > 0)
            {
                flag = 1;

                if(rem[i] <= tq)
                {
                    time += rem[i];
                    rem[i] = 0;
                    complete++;

                    tat[i] = time - arrival[i];
                    wt[i] = tat[i] - burst[i];

                    avg_wt += wt[i];
                    avg_tat += tat[i];
                }
                else
                {
                    time += tq;
                    rem[i] -= tq;
                }
            }
        }

        if(flag == 0)
            time++;
    }

    printf("\n%-15s %-15s %-15s %-15s\n",
           "Process No", "Burst Time", "TAT", "Waiting Time");

    for(i = 0; i < n; i++)
    {
        printf("Process No[%d] %-10d %-15d %-15d\n",
               i + 1, burst[i], tat[i], wt[i]);
    }

    printf("\nAverage Turn Around Time: %.6f", avg_tat / n);
    printf("\nAverage Waiting Time: %.6f\n", avg_wt / n);

    return 0;
}
