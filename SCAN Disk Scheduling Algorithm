#include <stdio.h>
#include <stdlib.h>

int main()
{
    int req[20], n, head, disk_size;
    int i, seek = 0;

    printf("Enter number of requests: ");
    scanf("%d", &n);

    printf("Enter request queue:\n");
    for(i = 0; i < n; i++)
        scanf("%d", &req[i]);

    printf("Enter initial head position: ");
    scanf("%d", &head);

    printf("Enter disk size: ");
    scanf("%d", &disk_size);

    seek = (disk_size - 1 - head);

    seek += (disk_size - 1);

    printf("\nTotal Seek Time = %d\n", seek);

    return 0;
}
