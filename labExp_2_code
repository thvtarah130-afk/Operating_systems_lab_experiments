#include <stdio.h>
#include <stdlib.h>

int main()
{
    FILE *fptr1, *fptr2;
    char sourceFile[100], destinationFile[100], c;

    printf("Enter the filename to open for reading\n");
    scanf("%s", sourceFile);

    fptr1 = fopen(sourceFile, "r");

    if (fptr1 == NULL)
    {
        printf("Cannot open file %s\n", sourceFile);
        exit(0);
    }

    printf("Enter the filename to open for writing\n");
    scanf("%s", destinationFile);

    fptr2 = fopen(destinationFile, "w");

    if (fptr2 == NULL)
    {
        printf("Cannot open file %s\n", destinationFile);
        exit(0);
    }

    c = fgetc(fptr1);

    while (c != EOF)
    {
        fputc(c, fptr2);
        c = fgetc(fptr1);
    }

    printf("\nContents copied to %s", destinationFile);

    fclose(fptr1);
    fclose(fptr2);

    return 0;
}
