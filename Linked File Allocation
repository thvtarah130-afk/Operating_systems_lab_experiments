#include <stdio.h>

int main()
{
    int n, i;
    int blocks[20];

    printf("Enter number of blocks allocated to file: ");
    scanf("%d", &n);

    printf("Enter block numbers:\n");
    for(i = 0; i < n; i++)
        scanf("%d", &blocks[i]);

    printf("\nLinked File Allocation:\n");

    for(i = 0; i < n - 1; i++)
    {
        printf("%d --> %d\n", blocks[i], blocks[i+1]);
    }

    printf("%d --> NULL\n", blocks[n-1]);

    return 0;
}
