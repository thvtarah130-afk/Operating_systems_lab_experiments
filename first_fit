#include <stdio.h>

int main() {
    int block[20], process[20];
    int m,n,i,j;

    printf("Enter number of blocks: ");
    scanf("%d",&m);

    for(i=0;i<m;i++)
        scanf("%d",&block[i]);

    printf("Enter number of processes: ");
    scanf("%d",&n);

    for(i=0;i<n;i++)
        scanf("%d",&process[i]);

    printf("\nProcess\tSize\tBlock\n");

    for(i=0;i<n;i++) {
        for(j=0;j<m;j++) {
            if(block[j] >= process[i]) {
                printf("%d\t%d\t%d\n",i+1,process[i],j+1);
                block[j]-=process[i];
                break;
            }
        }

        if(j==m)
            printf("%d\t%d\tNot Allocated\n",i+1,process[i]);
    }

    return 0;
}
