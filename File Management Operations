// Program 26: File Management Operations
#include <stdio.h>
#include <stdlib.h>

int main()
{
    FILE *fp;
    char ch;
    int choice;
    char data[100];

    while(1)
    {
        printf("\n1.Create & Write");
        printf("\n2.Read");
        printf("\n3.Append");
        printf("\n4.Delete");
        printf("\n5.Exit");

        printf("\nEnter choice: ");
        scanf("%d",&choice);

        switch(choice)
        {
            case 1:
                fp=fopen("file.txt","w");
                printf("Enter text: ");
                scanf(" %[^\n]",data);
                fprintf(fp,"%s",data);
                fclose(fp);
                printf("File created successfully");
                break;

            case 2:
                fp=fopen("file.txt","r");
                if(fp==NULL)
                {
                    printf("File not found");
                    break;
                }

                printf("\nContents:\n");
                while((ch=fgetc(fp))!=EOF)
                    printf("%c",ch);

                fclose(fp);
                break;

            case 3:
                fp=fopen("file.txt","a");
                printf("Enter text to append: ");
                scanf(" %[^\n]",data);
                fprintf(fp,"%s",data);
                fclose(fp);
                printf("Data appended");
                break;

            case 4:
                remove("file.txt");
                printf("File deleted");
                break;

            case 5:
                exit(0);
        }
    }
}
