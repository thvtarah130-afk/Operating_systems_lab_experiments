// Program 27: LS Command Simulation
#include <stdio.h>
#include <dirent.h>

int main()
{
    DIR *d;
    struct dirent *dir;

    d = opendir(".");

    if(d == NULL)
    {
        printf("Unable to open directory");
        return 1;
    }

    printf("Directory Contents:\n");

    while((dir = readdir(d)) != NULL)
    {
        printf("%s\n", dir->d_name);
    }

    closedir(d);

    return 0;
}
